---
import BaseLayout from './BaseLayout.astro';
import { normalizeTag } from '../utils/tags';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description?: string;
  canonicalUrl?: string;
  slug: string;
  draft?: boolean;
}

const { title, date, tags, description, canonicalUrl, slug, draft = false } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString().split('T')[0];
const isDev = import.meta.env.DEV;
const seoDescription = description ?? title;
---

<BaseLayout
  title={title}
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  publishedDate={isoDate}
>
  <article class="post">
    {isDev && draft && (
      <div class="draft-indicator" role="status">
        <span>Draft</span>
      </div>
    )}
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={isoDate}>{formattedDate}</time>
        {tags.length > 0 && (
          <ul class="post-tags" role="list" aria-label="Post tags">
            {tags.map((tag) => (
              <li>
                <a href={`/tags/${normalizeTag(tag)}`}>{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 80ch;
    margin: 0 auto;
  }

  .draft-indicator {
    background-color: #fef3c7;
    border: 1px solid #f59e0b;
    border-radius: 4px;
    padding: 0.5rem 1rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
    color: #92400e;
    font-size: 0.875rem;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-header h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .post-meta time {
    white-space: nowrap;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-tags li a {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background-color: #f1f5f9;
    border-radius: 4px;
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--color-primary);
    transition: background-color 0.2s ease;
  }

  .post-tags li a:hover {
    background-color: #e2e8f0;
    color: var(--color-primary-hover);
  }

  .post-content {
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(h4) {
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    background-color: #f8fafc;
    color: var(--color-text-muted);
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .post-content :global(pre) {
    margin: 1.5rem 0;
    max-width: 100%;
    overflow-x: auto;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 1.5rem 0;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    overflow-x: auto;
    display: block;
  }

  .post-content :global(th),
  .post-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .post-content :global(th) {
    background-color: #f8fafc;
    font-weight: 600;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.5rem;
    }

    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
