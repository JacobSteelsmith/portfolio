---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags } from '../../utils/tags.ts';
import { filterDrafts } from '../../utils/drafts.ts';

const allPosts = await getCollection('posts');
const publishedPosts = filterDrafts(allPosts);
const tagCounts = getAllTags(publishedPosts);

// Sort tags alphabetically and exclude any with zero published posts
const sortedTags = Array.from(tagCounts.entries())
  .filter(([_, count]) => count > 0)
  .sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout
  title="All Tags - Jacob Steelsmith"
  description="Browse all blog post tags on Jacob Steelsmith's technical blog."
>
  <h1>All Tags</h1>

  {sortedTags.length === 0 ? (
    <p>No tags found.</p>
  ) : (
    <ul class="tag-list">
      {sortedTags.map(([tag, count]) => (
        <li>
          <a href={`/tags/${tag}`} class="tag-link">
            <span class="tag-name">{tag}</span>
            <span class="tag-count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .tag-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background-color: #f1f5f9;
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-primary);
    font-size: 0.95rem;
    transition: background-color 0.15s ease;
  }

  .tag-link:hover {
    background-color: #e2e8f0;
    text-decoration: none;
  }

  .tag-name {
    font-weight: 500;
  }

  .tag-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.35rem;
    background-color: var(--color-primary);
    color: white;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 600;
  }
</style>
